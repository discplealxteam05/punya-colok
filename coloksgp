                                        background: linear-gradient(135deg, #fff8dc, #ffd700);
                                        color: #333;
                                    }

                                    .ColokSgP-fixed-footer .tada:hover img {
                                        filter: drop-shadow(0 0 15px #fff);
                                    }

                                    @keyframes floatUp {
                                        0% {
                                            opacity: 0;
                                            transform: translate(-50%, 50px);
                                        }

                                        100% {
                                            opacity: 1;
                                            transform: translate(-50%, 0);
                                        }
                                    }

